rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Open read/write for authenticated users (development mode)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Invite links — anyone can read (to verify invite before signing in)
    match /invites/{code} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Scorer links — anyone can read (no login required)
    match /scorerLinks/{code} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // At-bats — scorer needs to write without auth
    match /teams/{teamId}/atBats/{atBatId} {
      allow read, write: if true;
    }
  }
}
